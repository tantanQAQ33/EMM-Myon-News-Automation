e":"BlockDelay","data":{"disableBlock":false,"time":"2000"},"events":{},"id":"65miq9o","label":"delay","position":{"x":3919.0618356468044,"y":530.4187361349337}},{"type":"BlockBasic","data":{"code":"var links = [];\nvar items = document.querySelectorAll('.flex_item .articleList_cell > .link');\nitems.forEach(function(item) {\n    var href = item.getAttribute('href');\n    if (href) {\n        if (href.startsWith('/')) href = window.location.origin + href;\n        links.push(href);\n    }\n});\n// 随机选 11-13 个并反转\nvar count = Math.floor(Math.random() * 3) + 11;\nif (count > links.length) count = links.length;\nvar shuffled = links.sort(() => 0.5 - Math.random());\nvar selected = shuffled.slice(0, count).reverse();\n// 存入 localStorage（不依赖 Automa 变量）\nlocalStorage.setItem('myNewsLinks', JSON.stringify(selected));","context":"website","description":"","disableBlock":false,"everyNewTab":false,"preloadScripts":[],"runBeforeLoad":false,"timeout":20000},"events":{},"id":"y904l08","label":"javascript-code","position":{"x":4358.137322125464,"y":389.1592490951868}},{"type":"BlockBasic","data":{"code":"// ===== 辅助函数：模拟真实点击 =====\nfunction realClick(el) {\n    if (!el) return;\n    ['mousedown', 'mouseup', 'click'].forEach(function(type) {\n        el.dispatchEvent(new MouseEvent(type, { bubbles: true, cancelable: true }));\n    });\n}\n\n// ===== 1. 获取所有题目 =====\nvar allItems = document.querySelectorAll('.quiz_question');\nvar questions = [];\nfor (var i = 0; i < allItems.length; i++) {\n    questions.push(allItems[i]);\n}\n\n// ===== 2. 对每道题随机选一个选项 =====\nfor (var q = 0; q < questions.length; q++) {\n    var options = questions[q].querySelectorAll('.quiz_answer');\n    if (options.length === 0) continue;\n    var rand = Math.floor(Math.random() * options.length);\n    var selected = options[rand];\n    // 滚动到该选项，确保可见\n    selected.scrollIntoView({ behavior: 'smooth', block: 'center' });\n    var t = Date.now();\n    while (Date.now() - t < 300) {}\n    realClick(selected);\n    var t2 = Date.now();\n    while (Date.now() - t2 < 200) {}\n}\n\n// ===== 3. 点击提交按钮 =====\nvar submitBtn = document.querySelector('div.card_footer > .button');\nif (!submitBtn) {\n    submitBtn = document.querySelector('button.-checked');\n}\nif (submitBtn) {\n    submitBtn.scrollIntoView({ behavior: 'smooth', block: 'center' });\n    var waitSubmit = Date.now();\n    while (Date.now() - waitSubmit < 1000) {}\n    realClick(submitBtn);\n}","context":"website","description":"","disableBlock":false,"everyNewTab":false,"preloadScripts":[],"runBeforeLoad":false,"timeout":20000},"events":{},"id":"cw6bany","label":"javascript-code","position":{"x":4274.327529194418,"y":711.2398250868339}},{"type":"BlockDelay","data":{"disableBlock":false,"time":"3000"},"events":{},"id":"c5a5foz","label":"delay","position":{"x":5079.193443733384,"y":720.8305678575904}},{"type":"BlockBasic","data":{"description":"","disableBlock":false,"iconUrl":"","imageUrl":"","message":"","title":"全部完成"},"events":{},"id":"xdiqsm6","label":"notification","position":{"x":5854.446309899997,"y":384.97442331224636}},{"type":"BlockDelay","data":{"disableBlock":false,"time":"3000"},"events":{},"id":"um8g499","label":"delay","position":{"x":4521.04412788259,"y":540.9092020649722}},{"type":"BlockBasic","data":{"description":"","disableBlock":false,"findBy":"cssSelector","incX":false,"incY":false,"markEl":false,"multiple":false,"scrollIntoView":false,"scrollX":0,"scrollY":4000,"selector":"body","smooth":false,"waitForSelector":false,"waitSelectorTimeout":5000},"events":{},"id":"cec9q2f","label":"element-scroll","position":{"x":4793.085308966258,"y":558.3075997500589}},{"type":"BlockDelay","data":{"disableBlock":false,"time":"{{$randint(3000, 4000)}}"},"events":{},"id":"ozyp3bt","label":"delay","position":{"x":4530.4928242709175,"y":701.5309016235927}},{"type":"BlockBasic","data":{"code":"// 从 localStorage 取出下一个链接\nvar links = JSON.parse(localStorage.getItem('myNewsLinks') || '[]');\nvar currentLink = links.shift